# Jira credentials
JIRA_URL=https://warthogs.atlassian.net
JIRA_USERNAME=your-email@canonical.com
JIRA_PAT=your-jira-personal-access-token
JQL_FILTER=issuetype = Epic AND labels in (26.04, 26.10)

# PostgreSQL (matches docker-compose.yaml)
POSTGRESQL_DB_CONNECT_STRING=postgresql://roadmap:roadmap@localhost:5432/roadmap

# OIDC / OAuth 2.0 — leave OIDC_CLIENT_ID empty to disable auth
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=https://iam.green.canonical.com
OIDC_REDIRECT_URI=http://localhost:8000/callback
SESSION_SECRET=change-me-to-a-random-string
